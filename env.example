# Copy file này thành .env khi chạy local (bot.py không tự load .env,
# xem README phần "Chạy thử ở máy local" để biết cách nạp).
# Trên Render: khai báo các biến này trong tab Environment của service.

# BẮT BUỘC ----------------------------------------------------------------

# Token bot Telegram, lấy từ @BotFather.
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram user ID (số) được phép dùng bot - lấy bằng cách nhắn /start cho
# @userinfobot trên Telegram. Nhiều ID thì cách nhau bằng dấu phẩy.
ALLOWED_USER_IDS=111111111

# TÙY CHỌN ------------------------------------------------------------------

# polling (mặc định, dùng cho Background Worker/chạy local) hoặc webhook
# (dùng cho Web Service free tier trên Render - xem README).
MODE=polling

# Chỉ cần khi MODE=webhook VÀ không chạy trên Render (Render tự cấp
# RENDER_EXTERNAL_URL nên thường không cần điền tay biến này).
# WEBHOOK_URL=https://ten-app-cua-ban.onrender.com

# Chỉ cần khi MODE=webhook, để Telegram xác thực request gửi tới webhook.
# BẮT BUỘC chỉ gồm chữ, số, '_' và '-' (Telegram không cho phép ký tự khác
# như '/', '+', '=', ':'...). Tự sinh 1 chuỗi hợp lệ bằng:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# KHÔNG dùng generateValue:true trong render.yaml - giá trị Render tự sinh
# có thể chứa '/' hoặc '=' và sẽ bị Telegram từ chối (BadRequest).
# WEBHOOK_SECRET=doi-chuoi-nay-thanh-random

# appKey mtop của Lazada - hiếm khi cần đổi.
# LAZADA_APP_KEY=24677475

# Khởi tạo session Lazada ngay từ biến môi trường thay vì phải /setsession
# sau khi deploy lần đầu (dán nguyên lệnh curl, xem README). Chỉ dùng 1
# trong 2 biến dưới, curl được ưu tiên nếu có cả hai.
# LAZADA_CURL=curl 'https://acs-m.lazada.vn/...' -H 'accept: ...' -b '...'
# LAZADA_COOKIE=_m_h5_tk=xxxxx_1717000000000; _m_h5_tk_enc=xxxxx; ...

# Đường dẫn file lưu session (mặc định data/session.json, tương đối so với
# thư mục chạy bot). Trỏ vào Render Persistent Disk nếu muốn bền qua các
# lần deploy, vd /data/session.json.
# SESSION_FILE=data/session.json
